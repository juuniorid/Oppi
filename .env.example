PORT=3001

# Database Configuration
# For Docker: Use the default values below
# For Local: Update to your local PostgreSQL credentials
DATABASE_URL=postgresql://oppi:oppi@localhost:5432/oppi
DB_HOST=localhost
DB_PORT=5432

# Google OAuth 2.0 Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/
# 1. Create a new project
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add redirect URIs:
#    - http://localhost:3000/auth/callback
#    - http://localhost:3001/auth/google/callback
# 5. Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Google OAuth Callback URL
# For Docker: http://localhost:3001/v1/auth/google/callback
# For Production: https://yourdomain.com/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/v1/auth/google/callback

# JWT Secret for Token Generation
# Generate a secure random string (min 32 characters)
# You can use: openssl rand -base64 32
JWT_SECRET=your_secure_random_jwt_secret_here

# Frontend URL (used by API for CORS and OAuth redirect)
FRONTEND_URL=http://localhost:3000

# Test Database URL (required to run e2e tests)
TEST_DATABASE_URL=postgresql://oppi:oppi@localhost:5433/oppi_test

# Frontend API URL
# For Docker: http://localhost:3001/v1
# For Local Development: http://localhost:3001/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
